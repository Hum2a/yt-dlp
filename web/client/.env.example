# Copy this file to ".env" in the same folder (web/client).
# Vite reads VITE_* variables at dev and build time.

# API origin with NO trailing slash.
# - Leave empty for local dev: requests go to /api and Vite proxies to http://127.0.0.1:8000
# - Production (separate API host): https://your-service.onrender.com
VITE_API_BASE_URL=
