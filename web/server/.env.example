# Copy this file to ".env" in the same folder (web/server).
# Loaded automatically when the FastAPI app starts (python-dotenv).

# Comma-separated browser origins allowed to call the API (CORS).
# Local UI is already allowed by default; add your deployed frontend URL here, e.g.:
# YTDLP_CORS_ORIGINS=https://your-frontend.onrender.com
YTDLP_CORS_ORIGINS=

# Optional: absolute path for downloaded files (default: web/server/data/downloads)
# YTDLP_DOWNLOAD_DIR=

# Optional: SQLite file for first-party analytics
# YTDLP_ANALYTICS_DB=
